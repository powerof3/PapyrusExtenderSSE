{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "cmake-dev",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_CONFIGURATION_TYPES": "Debug;Release",
        "CMAKE_CXX_FLAGS": "/EHsc /MP /W4 /WX /external:W0 $penv{CXXFLAGS}",
        "CMAKE_CXX_FLAGS_RELEASE": "/O2 /DNDEBUG"
      },
      "errors": {
        "deprecated": true
      },
      "warnings": {
        "deprecated": true,
        "dev": true
      }
    },
    {
      "name": "vcpkg",
      "hidden": true,
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "VCPKG_OVERLAY_PORTS": "${sourceDir}/cmake/ports/"
      }
    },
    {
      "name": "windows",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreaded$<$<CONFIG:Debug>:Debug>",
        "VCPKG_TARGET_TRIPLET": "x64-windows-static"
      }
    },
    {
      "name": "base",
      "hidden": true,
      "inherits": [ "cmake-dev", "vcpkg", "windows" ]
    },
    {
      "name": "vs2022",
      "hidden": true,
      "generator": "Visual Studio 17 2022",
      "toolset": "v143"
    },
    {
      "name": "vs2026",
      "hidden": true,
      "generator": "Visual Studio 18 2026",
      "toolset": "v145"
    },
    {
      "name": "se",
      "hidden": true,
      "binaryDir": "${sourceDir}/build"
    },
    {
      "name": "ae",
      "hidden": true,
      "binaryDir": "${sourceDir}/buildae",
      "cacheVariables": {
        "BUILD_SKYRIMAE": true
      }
    },
    {
      "name": "vr",
      "hidden": true,
      "binaryDir": "${sourceDir}/buildvr",
      "cacheVariables": {
        "BUILD_SKYRIMVR": true
      }
    },
    {
      "name": "vs2022-se",
      "inherits": [ "base", "vs2022", "se" ]
    },
    {
      "name": "vs2022-ae",
      "inherits": [ "base", "vs2022", "ae" ]
    },
    {
      "name": "vs2022-vr",
      "inherits": [ "base", "vs2022", "vr" ]
    },
    {
      "name": "vs2026-se",
      "inherits": [ "base", "vs2026", "se" ]
    },
    {
      "name": "vs2026-ae",
      "inherits": [ "base", "vs2026", "ae" ]
    },
    {
      "name": "vs2026-vr",
      "inherits": [ "base", "vs2026", "vr" ]
    }
  ],
  "buildPresets": [
    {
      "name": "release",
      "hidden": true,
      "configuration": "Release"
    },
    {
      "name": "vs2022-se",
      "inherits": "release",
      "configurePreset": "vs2022-se"
    },
    {
      "name": "vs2022-ae",
      "inherits": "release",
      "configurePreset": "vs2022-ae"
    },
    {
      "name": "vs2022-vr",
      "inherits": "release",
      "configurePreset": "vs2022-vr"
    },
    {
      "name": "vs2026-se",
      "inherits": "release",
      "configurePreset": "vs2026-se"
    },
    {
      "name": "vs2026-ae",
      "inherits": "release",
      "configurePreset": "vs2026-ae"
    },
    {
      "name": "vs2026-vr",
      "inherits": "release",
      "configurePreset": "vs2026-vr"
    }
  ]
}
